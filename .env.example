APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info

POSTGRES_DB=gonow
POSTGRES_USER=gonow
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5433
DATABASE_URL=postgres://gonow:change_me@localhost:5432/gonow

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_a_long_random_development_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_development_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_CODE_TTL_SECONDS=600

PASSWORD_MIN_LENGTH=8
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_WINDOW_SECONDS=900
