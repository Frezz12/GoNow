APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info

POSTGRES_DB=gonow
POSTGRES_USER=gonow
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5433
DATABASE_URL=postgres://gonow:change_me@localhost:5433/gonow

REDIS_URL=redis://localhost:6379
REDIS_MAXMEMORY=256mb
REDIS_MEDIA_CACHE_TTL_SECONDS=86400
REDIS_MEDIA_CACHE_MAX_BYTES=4194304
REDIS_PROFILE_CACHE_TTL_SECONDS=60
REDIS_WEATHER_CACHE_TTL_SECONDS=300
REDIS_USER_STATUS_CACHE_TTL_SECONDS=30

JWT_ACCESS_SECRET=replace_with_a_long_random_development_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_development_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
PASSWORD_MIN_LENGTH=8
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_WINDOW_SECONDS=900

RESEND_API_KEY=re_replace_with_your_resend_api_key
RESEND_FROM_EMAIL="GoNow <noreply@mail.vlthub.ru>"
EMAIL_CODE_TTL_SECONDS=600

OBJECT_STORAGE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
OBJECT_STORAGE_BUCKET=gonow-development
OBJECT_STORAGE_ACCESS_KEY_ID=replace_with_your_s3_access_key_id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace_with_your_s3_secret_access_key
OBJECT_STORAGE_REGION=eu-central-003
OBJECT_STORAGE_KEY_PREFIX=gonow
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Apple Push Notification service. Leave every APNS_* value empty to disable
# remote pushes locally; the in-app notification center will still work.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_BASE64=
APNS_BUNDLE_ID=
APNS_ENVIRONMENT=sandbox
