    "NSLocationWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow verwendet deinen Standort für lokales Wetter und eine ungefähre Entfernung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show local weather and an approximate distance from you."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show local weather and an approximate distance from you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow usa tu ubicación para mostrar el tiempo local y una distancia aproximada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow utilise votre position pour la météo locale et une distance approximative."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GoNow usa sua localização para mostrar o clima local e uma distância aproximada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow использует геопозицию, чтобы показывать погоду и примерное расстояние до вас."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow 使用您的位置来显示当地天气和大致距离。"
