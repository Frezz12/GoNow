    "NSLocationWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow verwendet deinen Standort, um Aktivitäten in der Nähe, lokales Wetter und Entfernungen anzuzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show nearby activities, local weather, and distances."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show nearby activities, local weather, and distances."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow usa tu ubicación para mostrar actividades cercanas, el tiempo local y distancias."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow utilise votre position pour afficher les activités à proximité, la météo locale et les distances."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GoNow usa sua localização para mostrar atividades próximas, o clima local e distâncias."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow использует геопозицию, чтобы показывать активности рядом, местную погоду и расстояния."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow 使用您的位置来显示附近活动、当地天气和距离。"
          }
        }
      }
