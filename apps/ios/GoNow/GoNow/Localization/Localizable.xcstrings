    "map.location.permission.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow verwendet Ihren Standort, um Aktivitäten in der Nähe anzuzeigen und die Karte auf Sie zu zentrieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show nearby activities and center the map on you."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow uses your location to show nearby activities and center the map on you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow usa tu ubicación para mostrar actividades cercanas y centrar el mapa en ti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow utilise votre position pour afficher les activités à proximité et centrer la carte sur vous."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GoNow usa sua localização para mostrar atividades próximas e centralizar o mapa em você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GoNow использует вашу геопозицию, чтобы показать активности рядом и переместить карту к вам."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
